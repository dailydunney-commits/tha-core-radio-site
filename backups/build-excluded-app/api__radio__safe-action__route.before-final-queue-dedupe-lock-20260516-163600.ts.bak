import { NextRequest, NextResponse } from "next/server";
import { existsSync, mkdirSync, readFileSync, writeFileSync } from "node:fs";
import { join } from "node:path";

export const dynamic = "force-dynamic";
export const runtime = "nodejs";

type SafeActionPayload = {
  source?: string;
  action?: string;
  mode?: "metadata" | "preview" | "pre_broadcast" | "live_delay";
  requireClean?: boolean;
  track?: {
    id?: string;
    title?: string;
    artist?: string;
    source?: string;
    reason?: string;
    path?: string;
    audioUrl?: string;
    url?: string;
    streamUrl?: string;
    rawUrl?: string;
  };
  text?: string;
};

// ONE_TRUTH_HELD_BACKEND_GUARD_V1
function oneTruthTextFromPayload(payload: SafeActionPayload): string {
  const track: any = payload.track ?? {};

  return [
    payload.source,
    payload.action,
    payload.mode,
    payload.text,
    track.id,
    track.title,
    track.artist,
    track.source,
    track.reason,
    track.text,
    track.action,
    track.statusText,
    track.decision,
    track.message,
    track.safetyStatus,
  ]
    .filter(Boolean)
    .join(" ")
    .toLowerCase();
}

function oneTruthHasSafeAudio(payload: SafeActionPayload): boolean {
  const track: any = payload.track ?? {};

  return Boolean(
    track.cleanAudioUrl ||
      track.bleepedAudioUrl ||
      track.processedAudioUrl ||
      track.radioSafeAudioUrl
  );
}

function oneTruthHasAnyAudio(payload: SafeActionPayload): boolean {
  const track: any = payload.track ?? {};

  return Boolean(
    track.audioUrl ||
      track.url ||
      track.streamUrl ||
      track.rawUrl ||
      track.cleanAudioUrl ||
      track.bleepedAudioUrl ||
      track.processedAudioUrl ||
      track.radioSafeAudioUrl
  );
}

function oneTruthIsCleanOrBleeped(payload: SafeActionPayload): boolean {
  const text = oneTruthTextFromPayload(payload);

  return (
    oneTruthHasSafeAudio(payload) ||
    text.includes("clean_ready") ||
    text.includes("bleeped_safe") ||
    text.includes("radio_safe") ||
    text.includes("processed_audio_ready") ||
    text.includes("allow_completed_bleep_job") ||
    text.includes("approved clean") ||
    text.includes("clean audio") ||
    text.includes("bleeped audio")
  );
}

function oneTruthIsHeldOrUnsafe(payload: SafeActionPayload): boolean {
  const text = oneTruthTextFromPayload(payload);

  if (oneTruthIsCleanOrBleeped(payload)) return false;

  return (
    !oneTruthHasAnyAudio(payload) ||
    text.includes("held") ||
    text.includes("hold_dirty_audio") ||
    text.includes("dirty") ||
    text.includes("raw") ||
    text.includes("unverified") ||
    text.includes("explicit") ||
    text.includes("no clean") ||
    text.includes("needs clean") ||
    text.includes("clean/bleep") ||
    text.includes("no audio")
  );
}

function oneTruthBlockedResponse(payload: SafeActionPayload) {
  return NextResponse.json(
    {
      ok: false,
      route: "/api/radio/safe-action",
      decision: "BLOCKED_HELD_ONE_TRUTH",
      allowed: false,
      allowPreview: false,
      allowQueue: false,
      allowBroadcast: false,
      queued: false,
      source: payload.source ?? "CONTROL_PANEL",
      action: payload.action ?? "safe_action",
      message:
        "HELD - blocked by One Truth Safety Center. Needs clean/bleep copy before preview, queue, or broadcast.",
      track: payload.track ?? null,
      rule:
        "HELD anywhere = blocked everywhere. CLEAN anywhere = clean everywhere. BLEEPED anywhere = safe everywhere.",
    },
    {
      status: 423,
      headers: { "Cache-Control": "no-store" },
    }
  );
}
async function runBleepCheck(payload: SafeActionPayload, origin: string) {
  const url = `${origin}/api/radio/bleep-check`;

  const response = await fetch(url, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    cache: "no-store",
    body: JSON.stringify({
      source: payload.source ?? "CONTROL_PANEL",
      mode: payload.mode ?? "pre_broadcast",
      requireClean: payload.requireClean !== false,
      track: payload.track,
      text: payload.text,
    }),
  });

  return response.json();
}

const SMARTDJ_QUEUE_DIR = join(process.cwd(), ".data");
const SMARTDJ_QUEUE_FILE = join(SMARTDJ_QUEUE_DIR, "smartdj-safety-queue.json");

type SmartDjSafetyQueueItem = {
  id: string;
  createdAt: string;
  source: string;
  action: string;
  decision: string;
  message: string;
  track: SafeActionPayload["track"];
};

function readSmartDjSafetyQueue(): SmartDjSafetyQueueItem[] {
  try {
    if (!existsSync(SMARTDJ_QUEUE_FILE)) return [];
    const parsed = JSON.parse(readFileSync(SMARTDJ_QUEUE_FILE, "utf8"));
    return Array.isArray(parsed) ? parsed : [];
  } catch {
    return [];
  }
}

function saveSmartDjSafetyQueue(items: SmartDjSafetyQueueItem[]) {
  mkdirSync(SMARTDJ_QUEUE_DIR, { recursive: true });
  writeFileSync(SMARTDJ_QUEUE_FILE, JSON.stringify(items.slice(0, 50), null, 2), "utf8");
}

function addSmartDjSafetyQueueItem(payload: SafeActionPayload, message: string): SmartDjSafetyQueueItem {
  const track: any = payload.track ?? {};
  const item: SmartDjSafetyQueueItem = {
    id: `smartdj-${Date.now()}-${Math.random().toString(16).slice(2)}`,
    createdAt: new Date().toISOString(),
    source: payload.source ?? "CONTROL_PANEL",
    action: payload.action ?? "broadcast_action",
    decision: "ALLOW_TO_QUEUE",
    message,
    track: payload.track,
  };

  const items = readSmartDjSafetyQueue();

  const incomingTrackId = String(track?.id ?? "").trim();
  const incomingTitle = String(track?.title ?? "").trim().toLowerCase();

  const dedupedItems = items.filter((existing: any) => {
    const existingTrackId = String(existing?.track?.id ?? "").trim();
    const existingTitle = String(existing?.track?.title ?? "").trim().toLowerCase();

    if (incomingTrackId && existingTrackId) {
      return existingTrackId !== incomingTrackId;
    }

    if (incomingTitle && existingTitle) {
      return existingTitle !== incomingTitle;
    }

    return true;
  });

  dedupedItems.unshift(item);
  saveSmartDjSafetyQueue(dedupedItems);
  // SMARTDJ_SAFETY_QUEUE_DEDUPE_V1

  return item;
}
export async function GET() {
  return NextResponse.json(
    {
      ok: true,
      route: "/api/radio/safe-action",
      message: "Global safe action route online.",
      queueCount: readSmartDjSafetyQueue().length,
      queue: readSmartDjSafetyQueue(),
      flow:
        "Every control action can pass here first: bleep-check -> allow or bleep-job.",
      protects: [
        "AUTODJ",
        "SMARTDJ",
        "LIVEDJ",
        "REQUESTS",
        "UPLOADS",
        "PROMOS",
        "JINGLES",
        "ADS",
        "CONTROL_PANEL",
      ],
    },
    {
      headers: {
        "Cache-Control": "no-store",
      },
    }
  );
}

export async function DELETE(request: NextRequest) {
  try {
    const body = (await request.json().catch(() => ({}))) as {
      id?: string;
      clear?: boolean;
    };

    const currentQueue = readSmartDjSafetyQueue();

    if (body?.clear) {
      saveSmartDjSafetyQueue([]);

      return NextResponse.json(
        {
          ok: true,
          action: "clear_smartdj_safety_queue",
          removedCount: currentQueue.length,
          queueCount: 0,
          queue: [],
          message: "SmartDJ safety queue cleared.",
        },
        {
          headers: {
            "Cache-Control": "no-store",
          },
        }
      );
    }

    const id = String(body?.id ?? "").trim();

    if (!id) {
      return NextResponse.json(
        {
          ok: false,
          action: "remove_smartdj_safety_queue_item",
          removedCount: 0,
          queueCount: currentQueue.length,
          queue: currentQueue,
          message: "Missing SmartDJ safety queue item id.",
        },
        {
          status: 400,
          headers: {
            "Cache-Control": "no-store",
          },
        }
      );
    }

    const nextQueue = currentQueue.filter((item) => item.id !== id);
    const removedCount = currentQueue.length - nextQueue.length;

    saveSmartDjSafetyQueue(nextQueue);

    return NextResponse.json(
      {
        ok: true,
        action: "remove_smartdj_safety_queue_item",
        removedCount,
        queueCount: nextQueue.length,
        queue: nextQueue,
        message:
          removedCount > 0
            ? "SmartDJ safety queue item removed."
            : "SmartDJ safety queue item was not found.",
      },
      {
        headers: {
          "Cache-Control": "no-store",
        },
      }
    );
  } catch {
    return NextResponse.json(
      {
        ok: false,
        action: "smartdj_safety_queue_delete_failed",
        message: "Could not update SmartDJ safety queue.",
      },
      {
        status: 500,
        headers: {
          "Cache-Control": "no-store",
        },
      }
    );
  }
}
export async function POST(request: NextRequest) {
  try {
    const payload = (await request.json().catch(() => ({}))) as SafeActionPayload;
    const oneTruthAction = String(payload.action ?? "").toLowerCase();
    const oneTruthIsQueueAdminAction = Boolean(
      (payload as any)?.clear ||
        (payload as any)?.id ||
        oneTruthAction.includes("clear") ||
        oneTruthAction.includes("remove")
    );

    if (!oneTruthIsQueueAdminAction && oneTruthIsHeldOrUnsafe(payload)) {
      return oneTruthBlockedResponse(payload);
    }
    const origin = request.nextUrl.origin;

    const bleep = await runBleepCheck(payload, origin);
    let queuedItem: SmartDjSafetyQueueItem | null = null;

    if (bleep?.needsBleep || bleep?.decision === "CREATE_BLEEP_JOB") {
      return NextResponse.json(
        {
          ok: true,
          allowed: false,
          source: payload.source ?? "CONTROL_PANEL",
          action: payload.action ?? "broadcast_action",
          decision: "CREATE_BLEEP_JOB",
          message:
            bleep?.message ||
            "BLEEP JOB CREATED - clean or processed bleeped copy required before broadcast.",
          bleep,
        },
        {
          headers: {
            "Cache-Control": "no-store",
          },
        }
      );
    }

    return NextResponse.json(
      {
        ok: true,
        allowed: true,
        source: payload.source ?? "CONTROL_PANEL",
        action: payload.action ?? "broadcast_action",
        decision: "ALLOW_TO_QUEUE",
        message: "Passed global radio bleep check. Action allowed.",
        queued: true,
        queueMessage: "Queued in SmartDJ local safety queue.",
        queueItem: (queuedItem = addSmartDjSafetyQueueItem(payload, "Passed Global Bleep Gate. Queued in SmartDJ safety queue.")),
        bleep,
      },
      {
        headers: {
          "Cache-Control": "no-store",
        },
      }
    );
  } catch (error) {
    return NextResponse.json(
      {
        ok: false,
        allowed: false,
        decision: "HOLD_BEFORE_BROADCAST",
        message:
          error instanceof Error
            ? error.message
            : "Global safe action failed. Hold before broadcast.",
      },
      { status: 500 }
    );
  }
}





