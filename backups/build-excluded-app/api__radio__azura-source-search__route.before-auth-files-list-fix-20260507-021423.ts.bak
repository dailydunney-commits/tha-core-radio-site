import { NextRequest, NextResponse } from "next/server";

export const dynamic = "force-dynamic";
export const runtime = "nodejs";

type SourceTrack = {
  id: string;
  title: string;
  artist: string;
  source: string;
  reason: string;
  audioUrl: string;
  url: string;
  streamUrl: string;
  rawUrl?: string;
};

function getAzuraBaseUrl(): string {
  return (
    process.env.AZURACAST_BASE_URL ||
    process.env.NEXT_PUBLIC_AZURACAST_BASE_URL ||
    "http://thacoreonlinerad.com"
  ).replace(/\/+$/, "");
}

function getAzuraStationId(): string {
  return (
    process.env.AZURACAST_STATION_ID ||
    process.env.NEXT_PUBLIC_AZURACAST_STATION_ID ||
    "1"
  );
}

function normalize(value: unknown): string {
  return String(value ?? "")
    .toLowerCase()
    .replace(/[^\w\s]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function getAnyString(...values: unknown[]): string {
  for (const value of values) {
    if (typeof value === "string" && value.trim()) return value.trim();
    if (typeof value === "number") return String(value);
  }

  return "";
}

function toAbsoluteUrl(value: unknown): string {
  if (typeof value !== "string" || !value.trim()) return "";

  const raw = value.trim();

  if (raw.startsWith("http://") || raw.startsWith("https://")) return raw;
  if (raw.startsWith("/")) return `${getAzuraBaseUrl()}${raw}`;

  return "";
}

function extractAudioUrl(item: any): string {
  const direct = getAnyString(
    item?.audioUrl,
    item?.streamUrl,
    item?.url,
    item?.download_url,
    item?.downloadUrl,
    item?.play_url,
    item?.playUrl,
    item?.links?.download,
    item?.links?.play,
    item?.links?.self,
    item?.media?.download_url,
    item?.media?.downloadUrl,
    item?.media?.play_url,
    item?.media?.playUrl
  );

  return toAbsoluteUrl(direct);
}

function mediaText(item: any): string {
  return normalize(
    [
      item?.id,
      item?.unique_id,
      item?.media_id,
      item?.title,
      item?.artist,
      item?.name,
      item?.path,
      item?.media_file,
      item?.song?.title,
      item?.song?.artist,
      item?.media?.title,
      item?.media?.artist,
      item?.media?.path,
      item?.extra_metadata?.artist,
      item?.extra_metadata?.title,
    ]
      .filter(Boolean)
      .join(" ")
  );
}

function collectObjects(value: any, depth = 0): any[] {
  if (!value || depth > 6) return [];

  if (Array.isArray(value)) {
    return value.flatMap((item) => collectObjects(item, depth + 1));
  }

  if (typeof value === "object") {
    const looksLikeMedia =
      value.id ||
      value.unique_id ||
      value.media_id ||
      value.title ||
      value.name ||
      value.path ||
      value.song ||
      value.media ||
      value.media_file;

    const nested = Object.values(value).flatMap((item) =>
      collectObjects(item, depth + 1)
    );

    return looksLikeMedia ? [value, ...nested] : nested;
  }

  return [];
}

function normalizeTrack(item: any, index: number): SourceTrack {
  const artist = getAnyString(
    item?.artist,
    item?.song?.artist,
    item?.media?.artist,
    item?.extra_metadata?.artist,
    "AzuraCast"
  );

  const title = getAnyString(
    item?.title,
    item?.song?.title,
    item?.media?.title,
    item?.extra_metadata?.title,
    item?.name,
    item?.path,
    `AzuraCast Track ${index + 1}`
  );

  const rawUrl = extractAudioUrl(item);
  const proxied = rawUrl ? `/api/smartdj/audio?src=${encodeURIComponent(rawUrl)}` : "";

  return {
    id: String(
      item?.id ??
        item?.unique_id ??
        item?.media_id ??
        item?.path ??
        `azura-source-${Date.now()}-${index}`
    ),
    title,
    artist,
    source: "AzuraCast Source Search",
    reason: rawUrl
      ? "Manual source match found for bleep processing."
      : "Manual source metadata found, but no direct audio URL returned.",
    audioUrl: proxied,
    url: proxied,
    streamUrl: proxied,
    rawUrl,
  };
}

function buildUrls(query: string) {
  const baseUrl = getAzuraBaseUrl();
  const stationId = getAzuraStationId();
  const q = encodeURIComponent(query);

  return [
    `${baseUrl}/api/station/${stationId}/files?search=${q}`,
    `${baseUrl}/api/station/${stationId}/files?query=${q}`,
    `${baseUrl}/api/station/${stationId}/files?q=${q}`,
    `${baseUrl}/api/station/${stationId}/files?keyword=${q}`,
    `${baseUrl}/api/station/${stationId}/files?search=${q}&page=1&rowCount=500`,
    `${baseUrl}/api/station/${stationId}/files?query=${q}&page=1&rowCount=500`,
    `${baseUrl}/api/station/${stationId}/files?q=${q}&page=1&rowCount=500`,
    `${baseUrl}/api/station/${stationId}/files?page=1&rowCount=500`,
    `${baseUrl}/api/station/${stationId}/files?page=2&rowCount=500`,
    `${baseUrl}/api/station/${stationId}/files?page=3&rowCount=500`,
  ];
}

async function fetchJsonFast(url: string, apiKey: string) {
  const controller = new AbortController();
  const timer = setTimeout(() => controller.abort(), 5000);

  try {
    const headers: HeadersInit = { Accept: "application/json" };

    if (apiKey) headers["X-API-Key"] = apiKey;

    const response = await fetch(url, {
      method: "GET",
      headers,
      cache: "no-store",
      signal: controller.signal,
    });

    if (!response.ok) return null;
    return response.json();
  } catch {
    return null;
  } finally {
    clearTimeout(timer);
  }
}

function scoreItem(item: any, query: string) {
  const text = mediaText(item);
  const words = normalize(query)
    .split(" ")
    .filter((word) => word.length >= 3);

  let score = 0;

  for (const word of words) {
    if (text.includes(word)) score += 20;
  }

  if (query.toLowerCase().includes("mother") && text.includes("mother")) score += 60;
  if (extractAudioUrl(item)) score += 30;
  if (text.includes("mp3")) score += 5;

  return score;
}

export async function POST(request: NextRequest) {
  try {
    const body = await request.json().catch(() => null);
    const query = String(body?.query ?? "").trim();

    if (!query) {
      return NextResponse.json(
        {
          ok: false,
          results: [],
          count: 0,
          message: "Missing source search query.",
        },
        { status: 400 }
      );
    }

    const apiKey = process.env.AZURACAST_API_KEY || "";
    const urls = Array.from(new Set(buildUrls(query)));

    const settled = await Promise.allSettled(urls.map((url) => fetchJsonFast(url, apiKey)));
    const collected = new Map<string, any>();

    for (const result of settled) {
      if (result.status !== "fulfilled") continue;

      const objects = collectObjects(result.value);

      for (const item of objects) {
        const score = scoreItem(item, query);
        if (score <= 0) continue;

        const key = String(
          item?.id ??
            item?.unique_id ??
            item?.media_id ??
            item?.path ??
            JSON.stringify(item)
        );

        if (!collected.has(key)) collected.set(key, item);
      }
    }

    const results = Array.from(collected.values())
      .map((item, index) => ({
        item,
        score: scoreItem(item, query),
        track: normalizeTrack(item, index),
      }))
      .sort((a, b) => b.score - a.score)
      .slice(0, 15)
      .map((entry) => entry.track);

    return NextResponse.json(
      {
        ok: true,
        query,
        count: results.length,
        results,
        message:
          results.length > 0
            ? `Found ${results.length} source match(es).`
            : "No source matches found.",
      },
      {
        headers: {
          "Cache-Control": "no-store",
        },
      }
    );
  } catch (error) {
    return NextResponse.json(
      {
        ok: false,
        results: [],
        count: 0,
        message:
          error instanceof Error
            ? error.message
            : "Source search failed.",
      },
      { status: 500 }
    );
  }
}
